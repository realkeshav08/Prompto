GEMINI_API_KEY=your_gemini_api_key_here
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=quickgpt

# Shared secret — must match INTERNAL_API_KEY in server/.env.
# When set, every AI endpoint rejects callers that don't present it.
INTERNAL_API_KEY=generate_a_long_random_string
