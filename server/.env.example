JWT_SECRET=your_jwt_secret_here

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Cluster0

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# ImageKit
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# Stripe
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Email (Gmail account + app password)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Python AI microservice
PYTHON_AI_URL=http://localhost:8000

# Shared secret sent to the Python AI service. Set the SAME value in
# python-service/.env so the AI service rejects any other caller.
INTERNAL_API_KEY=generate_a_long_random_string

# Frontend origin (for CORS)
CLIENT_URL=https://your-frontend-domain.com

# Email of the account allowed to upload shared/global Study AI documents.
# Leave unset to disable global uploads entirely.
ADMIN_EMAIL=you@example.com
